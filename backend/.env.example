# =========================
# APP CONFIG
# =========================
NODE_ENV=development
PORT=3000

# =========================
# DATABASE (PostgreSQL)
# =========================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supplycycle

# =========================
# AUTH (JWT)
# =========================
JWT_SECRET=supplycycle-dev-secret-key-2026
JWT_EXPIRES_IN=24h

# =========================
# BCRYPT / SECURITY
# =========================
BCRYPT_SALT_ROUNDS=10

# =========================
# CORS
# =========================
CORS_ORIGIN=*

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug

# =========================
# WHATSAPP BOT
# =========================
BOT_API_KEY=sc-bot-dev-key-change-in-production
