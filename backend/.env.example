# =========================
# APP CONFIG
# =========================
NODE_ENV=development
PORT=3000

# =========================
# DATABASE
# =========================
DATABASE_URL=

# MongoDB en vez de Postgres:
# MONGODB_URI=

# =========================
# AUTH (JWT)
# =========================
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# =========================
# BCRYPT / SECURITY
# =========================
BCRYPT_SALT_ROUNDS=

# =========================
# CORS
# =========================
CORS_ORIGIN=

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug

# =========================
# RATE LIMITING
# =========================
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=

# =========================
# EMAIL SERVICE
# =========================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# =========================
# FILE STORAGE
# =========================
UPLOAD_DIR=
MAX_FILE_SIZE=

# =========================
# REDIS (cache / sessions)
# =========================
REDIS_URL=

# =========================
# FRONTEND URL
# =========================
CLIENT_URL=