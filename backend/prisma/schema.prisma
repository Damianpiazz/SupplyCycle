generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  REPARTIDOR
  ADMIN
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
}

enum EstadoPedido {
  PENDIENTE
  ENTREGADO
  NO_ENTREGADO
}

enum EstadoReparto {
  PENDIENTE
  EN_CURSO
  COMPLETADO
}

model Usuario {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  nombre        String   @db.VarChar(100)
  apellido      String   @db.VarChar(100)
  rol           Rol      @default(REPARTIDOR)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  repartos      Reparto[]
}

model Cliente {
  id            String    @id @default(uuid())
  nombre        String    @db.VarChar(100)
  apellido      String    @db.VarChar(100)
  telefono      String    @db.VarChar(20)
  calle         String
  numero        String
  localidad     String
  latitud       Float
  longitud      Float
  diaEntrega    DiaSemana
  horarioDesde  String
  horarioHasta  String
  observaciones String?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  pedidos       Pedido[]
}

model Item {
  id          String       @id @default(uuid())
  nombre      String       @db.VarChar(100)
  descripcion String?
  unidad      String
  activo      Boolean      @default(true)
  creadoEn    DateTime     @default(now())
  pedidoItems PedidoItem[]
}

model Pedido {
  id            String        @id @default(uuid())
  clienteId     String
  repartoId     String
  fecha         DateTime
  estado        EstadoPedido  @default(PENDIENTE)
  motivoFalla   String?
  orden         Int
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  cliente       Cliente       @relation(fields: [clienteId], references: [id])
  reparto       Reparto       @relation(fields: [repartoId], references: [id])
  items         PedidoItem[]

  @@unique([clienteId, fecha])
}

model PedidoItem {
  id       String @id @default(uuid())
  pedidoId String
  itemId   String
  cantidad Int
  pedido   Pedido @relation(fields: [pedidoId], references: [id])
  item     Item   @relation(fields: [itemId], references: [id])
}

model Reparto {
  id            String        @id @default(uuid())
  repartidorId  String
  fecha         DateTime      @db.Date
  estado        EstadoReparto @default(PENDIENTE)
  horaInicio    String?
  horaFin       String?
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  repartidor    Usuario       @relation(fields: [repartidorId], references: [id])
  pedidos       Pedido[]

  @@unique([repartidorId, fecha])
}
