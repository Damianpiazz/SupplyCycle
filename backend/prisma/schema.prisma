generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  REPARTIDOR
  ADMIN
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum EstadoPedido {
  PENDIENTE
  EN_RUTA
  ENTREGADO
  NO_ENTREGADO
  CANCELADO
}

enum EstadoReparto {
  PENDIENTE
  EN_CURSO
  COMPLETADO
}

enum EstadoRetenido {
  RETENIDO
  DEVUELTO
  PERDIDO
}

model Usuario {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  nombre        String   @db.VarChar(100)
  apellido      String   @db.VarChar(100)
  rol           Rol      @default(REPARTIDOR)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  repartos      Reparto[]
}

model Cliente {
  id            String    @id @default(uuid())
  nombre        String    @db.VarChar(100)
  apellido      String    @db.VarChar(100)
  telefono      String    @db.VarChar(20)
  observaciones String?
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  domicilios    Domicilio[]
  retenidos     Retenido[]
  reclamos      Reclamo[]
}

model Item {
  id          String       @id @default(uuid())
  nombre      String       @db.VarChar(100)
  descripcion String?
  unidad      String
  precio      Float?
  activo      Boolean      @default(true)
  creadoEn    DateTime     @default(now())
  pedidoItems PedidoItem[]
  retenidos   Retenido[]
}

model Pedido {
  id            String        @id @default(uuid())
  numeroPedido  String        @unique @map("numero_pedido") @db.VarChar(20)
  domicilioId   String
  repartoId     String?
  fecha         DateTime
  estado        EstadoPedido  @default(PENDIENTE)
  motivoFalla   String?
  orden         Int
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  deletedAt     DateTime?
  domicilio     Domicilio     @relation(fields: [domicilioId], references: [id])
  reparto       Reparto?      @relation(fields: [repartoId], references: [id])
  items         PedidoItem[]
  visitas       Visita[]
  retenidos     Retenido[]
}

model PedidoItem {
  id            String @id @default(uuid())
  pedidoId      String
  itemId        String
  cantidad      Int
  precioUnitario Float?
  pedido        Pedido @relation(fields: [pedidoId], references: [id])
  item          Item   @relation(fields: [itemId], references: [id])
}

model Reparto {
  id            String        @id @default(uuid())
  repartidorId  String
  fecha         DateTime      @db.Date
  estado        EstadoReparto @default(PENDIENTE)
  horaInicio    String?
  horaFin       String?
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  repartidor    Usuario       @relation(fields: [repartidorId], references: [id])
  pedidos       Pedido[]

  @@unique([repartidorId, fecha])
}

model Ciudad {
  id         String      @id @default(uuid())
  nombre     String      @db.VarChar(100)
  creadoEn   DateTime    @default(now())
  domicilios Domicilio[]
}

model Domicilio {
  id          String   @id @default(uuid())
  calle       String   @db.VarChar(200)
  entreCalle1 String?
  entreCalle2 String?
  numero      String   @db.VarChar(20)
  piso        String?
  localidad   String   @db.VarChar(200)
  latitud     Float?
  longitud    Float?
  principal   Boolean  @default(true)
  clienteId   String
  ciudadId    String
  creadoEn    DateTime @default(now())
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  ciudad      Ciudad   @relation(fields: [ciudadId], references: [id])
  dias        Dia[]
  pedidos     Pedido[]
}

model Dia {
  id          String     @id @default(uuid())
  nombre      DiaSemana
  domicilioId String
  creadoEn    DateTime   @default(now())
  domicilio   Domicilio  @relation(fields: [domicilioId], references: [id])
  horarios    Horario[]
}

model Horario {
  id       String   @id @default(uuid())
  inicio   DateTime
  fin      DateTime
  diaId    String
  creadoEn DateTime @default(now())
  dia      Dia      @relation(fields: [diaId], references: [id])
}

model Empleado {
  id            String   @id @default(uuid())
  nombre        String   @db.VarChar(100)
  apellido      String   @db.VarChar(100)
  dni           String   @unique @db.VarChar(20)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  visitas       Visita[]
}

model Visita {
  id         String   @id @default(uuid())
  fecha      DateTime @db.Date
  hora       DateTime
  falta      Boolean  @default(false)
  pedidoId   String
  empleadoId String
  creadoEn   DateTime @default(now())
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
}

model Retenido {
  id        String         @id @default(uuid())
  estado    EstadoRetenido @default(RETENIDO)
  inicio    DateTime
  fin       DateTime?
  itemId    String
  clienteId String
  pedidoId  String
  creadoEn  DateTime       @default(now())
  item      Item           @relation(fields: [itemId], references: [id])
  cliente   Cliente        @relation(fields: [clienteId], references: [id])
  pedido    Pedido         @relation(fields: [pedidoId], references: [id])
}

model Reclamo {
  id        String   @id @default(uuid())
  clienteId String
  creadoEn  DateTime @default(now())
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
}
