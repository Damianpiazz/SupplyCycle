<%- include('../layouts/header') %>
<header class="flex justify-between items-center mb-3">
  <div><span class="text-muted"><%= total %> días</span></div>
  <a href="/admin/dias/nuevo" role="button" class="primary">Nuevo Día</a>
</header>
<form method="GET" class="flex gap-2 mb-3 items-center">
  <select name="dia" style="width:auto">
    <option value="">Todos</option>
    <% DIAS_SEMANA.forEach(d => { %>
      <option value="<%= d %>" <%= filtroDia === d ? 'selected' : '' %>><%= d.charAt(0) + d.slice(1).toLowerCase() %></option>
    <% }) %>
  </select>
  <button type="submit" class="secondary outline">Filtrar</button>
</form>
<table>
  <thead>
    <tr><th>Día</th><th>Cliente</th><th>Dirección</th><th>Ciudad</th><th></th></tr>
  </thead>
  <tbody>
    <% dias.forEach(d => { %>
      <tr>
        <td><%= d.nombre.charAt(0) + d.nombre.slice(1).toLowerCase() %></td>
        <td><%= d.domicilio.cliente.apellido %>, <%= d.domicilio.cliente.nombre %></td>
        <td><%= d.domicilio.calle %> <%= d.domicilio.numero %></td>
        <td><%= d.domicilio.ciudad.nombre %></td>
        <td class="action-cell">
          <a href="/admin/dias/<%= d.id %>/editar" role="button" class="secondary outline small-btn">Editar</a>
          <form method="POST" action="/admin/dias/<%= d.id %>/eliminar" onsubmit="return confirm('¿Eliminar este día?')">
            <button type="submit" class="secondary outline small-btn">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (dias.length === 0) { %>
      <tr><td colspan="5" class="text-center text-muted" style="padding:1rem 0">No hay días registrados</td></tr>
    <% } %>
  </tbody>
</table>
<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
