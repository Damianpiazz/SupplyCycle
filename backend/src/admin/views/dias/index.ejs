<%- include('../layouts/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><span class="text-muted"><%= total %> días</span></div>
  <a href="/admin/dias/nuevo" class="btn btn-primary">Nuevo Día</a>
</div>
<form method="GET" class="row g-2 mb-3">
  <div class="col-auto">
    <select class="form-select form-select-sm" name="dia">
      <option value="">Todos</option>
      <% DIAS_SEMANA.forEach(d => { %>
        <option value="<%= d %>" <%= filtroDia === d ? 'selected' : '' %>><%= d.charAt(0) + d.slice(1).toLowerCase() %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-outline-secondary btn-sm">Filtrar</button>
  </div>
</form>
<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr><th>Día</th><th>Cliente</th><th>Dirección</th><th>Ciudad</th><th></th></tr>
    </thead>
    <tbody>
      <% dias.forEach(d => { %>
        <tr>
          <td><%= d.nombre.charAt(0) + d.nombre.slice(1).toLowerCase() %></td>
          <td><%= d.domicilio.cliente.apellido %>, <%= d.domicilio.cliente.nombre %></td>
          <td><%= d.domicilio.calle %> <%= d.domicilio.numero %></td>
          <td><%= d.domicilio.ciudad.nombre %></td>
          <td>
            <a href="/admin/dias/<%= d.id %>/editar" class="btn btn-sm btn-outline-primary">Editar</a>
            <form method="POST" action="/admin/dias/<%= d.id %>/eliminar" style="display:inline" onsubmit="return confirm('¿Eliminar este día?')">
              <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (dias.length === 0) { %>
        <tr><td colspan="5" class="text-center text-muted py-4">No hay días registrados</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
