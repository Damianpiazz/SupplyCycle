<%- include('../layouts/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><span class="text-muted"><%= ciudades.length %> ciudades</span></div>
  <a href="/admin/ciudades/nuevo" class="btn btn-primary">Nueva Ciudad</a>
</div>
<form method="GET" class="row g-2 mb-3">
  <div class="col-auto">
    <input type="text" class="form-control form-control-sm" name="search" placeholder="Buscar..." value="<%= search %>">
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-outline-secondary btn-sm">Buscar</button>
  </div>
</form>
<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr><th>Nombre</th><th>Creado</th><th></th></tr>
    </thead>
    <tbody>
      <% ciudades.forEach(c => { %>
        <tr>
          <td><%= c.nombre %></td>
          <td><%= c.creadoEn.toLocaleDateString() %></td>
          <td>
            <a href="/admin/ciudades/<%= c.id %>/editar" class="btn btn-sm btn-outline-primary">Editar</a>
            <form method="POST" action="/admin/ciudades/<%= c.id %>/eliminar" style="display:inline" onsubmit="return confirm('¿Eliminar esta ciudad?')">
              <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (ciudades.length === 0) { %>
        <tr><td colspan="3" class="text-center text-muted py-4">No hay ciudades</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<%- include('../layouts/footer') %>
