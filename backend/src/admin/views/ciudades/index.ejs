<%- include('../layouts/header') %>
<header class="flex justify-between items-center mb-3">
  <div><span class="text-muted"><%= ciudades.length %> ciudades</span></div>
  <a href="/admin/ciudades/nuevo" role="button" class="primary">Nueva Ciudad</a>
</header>
<form method="GET" class="flex gap-2 mb-3 items-center">
  <input type="text" name="search" placeholder="Buscar..." value="<%= search %>">
  <button type="submit" class="secondary outline">Buscar</button>
</form>
<table>
  <thead>
    <tr><th>Nombre</th><th>Creado</th><th></th></tr>
  </thead>
  <tbody>
    <% ciudades.forEach(c => { %>
      <tr>
        <td><%= c.nombre %></td>
        <td><%= c.creadoEn.toLocaleDateString() %></td>
        <td class="action-cell">
          <a href="/admin/ciudades/<%= c.id %>/editar" role="button" class="secondary outline small-btn">Editar</a>
          <form method="POST" action="/admin/ciudades/<%= c.id %>/eliminar" onsubmit="return confirm('¿Eliminar esta ciudad?')">
            <button type="submit" class="secondary outline small-btn">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (ciudades.length === 0) { %>
      <tr><td colspan="3" class="text-center text-muted" style="padding:1rem 0">No hay ciudades</td></tr>
    <% } %>
  </tbody>
</table>
<%- include('../layouts/footer') %>
