<%- include('../layouts/header') %>
<a href="/admin/ciudades" class="secondary outline small-btn mb-2">&larr; Volver</a>
<article>
  <header><strong><%= ciudad ? 'Editar' : 'Nueva' %> Ciudad</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>
  <form method="POST" action="/admin/ciudades<%= ciudad ? '/' + ciudad.id : '' %>">
    <label for="nombre">Nombre
      <input type="text" id="nombre" name="nombre" value="<%= ciudad ? ciudad.nombre : '' %>" required>
    </label>
    <footer class="flex gap-2">
      <button type="submit" class="primary"><%= ciudad ? 'Guardar Cambios' : 'Crear Ciudad' %></button>
      <a href="/admin/ciudades" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>
<%- include('../layouts/footer') %>
