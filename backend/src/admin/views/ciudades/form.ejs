<%- include('../layouts/header') %>
<div class="mb-3">
  <a href="/admin/ciudades" class="btn btn-outline-secondary btn-sm">&larr; Volver</a>
</div>
<div class="card">
  <div class="card-header"><strong><%= ciudad ? 'Editar' : 'Nueva' %> Ciudad</strong></div>
  <div class="card-body">
    <% if (typeof errors.general !== 'undefined' && errors.general) { %>
      <div class="alert alert-danger"><%= errors.general %></div>
    <% } %>
    <form method="POST" action="/admin/ciudades<%= ciudad ? '/' + ciudad.id : '' %>">
      <div class="mb-3">
        <label for="nombre" class="form-label">Nombre</label>
        <input type="text" class="form-control" id="nombre" name="nombre" value="<%= ciudad ? ciudad.nombre : '' %>" required>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><%= ciudad ? 'Guardar Cambios' : 'Crear Ciudad' %></button>
        <a href="/admin/ciudades" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
<%- include('../layouts/footer') %>
