<%- include('../layouts/header') %>

<a href="/admin/repartos" class="secondary outline small-btn mb-2">&larr; Volver</a>

<article>
  <header><strong>Nuevo Reparto</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>

  <form method="POST" action="/admin/repartos">
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="repartidorId">Repartidor
        <select id="repartidorId" name="repartidorId" required>
          <option value="">Seleccionar repartidor...</option>
          <% repartidores.forEach(r => { %>
            <option value="<%= r.id %>"><%= r.apellido %>, <%= r.nombre %></option>
          <% }) %>
        </select>
      </label>

      <label for="fecha">Fecha
        <input type="date" id="fecha" name="fecha" value="<%= new Date().toISOString().slice(0, 10) %>" required>
      </label>
    </div>

    <label>Pedidos disponibles</label>
    <% if (pedidosDisponibles.length === 0) { %>
      <small>No hay pedidos pendientes sin asignar para esta fecha.</small>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th style="width:40px">
              <input type="checkbox" id="select-all">
            </th>
            <th>#</th>
            <th>Cliente</th>
            <th>Items</th>
          </tr>
        </thead>
        <tbody>
          <% pedidosDisponibles.forEach(p => { %>
            <tr>
              <td>
                <input type="checkbox" name="pedidoIds" value="<%= p.id %>" class="pedido-check">
              </td>
              <td><%= p.numeroPedido %></td>
              <td><%= p.cliente.apellido %>, <%= p.cliente.nombre %></td>
              <td><%= p.itemsCount %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <footer class="flex gap-2">
      <button type="submit" class="primary">Crear Reparto</button>
      <a href="/admin/repartos" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>

<script>
  document.getElementById('select-all')?.addEventListener('change', function() {
    document.querySelectorAll('.pedido-check').forEach(cb => cb.checked = this.checked);
  });
</script>

<%- include('../layouts/footer') %>
