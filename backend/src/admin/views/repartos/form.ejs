<%- include('../layouts/header') %>

<div class="mb-3">
  <a href="/admin/repartos" class="btn btn-outline-secondary btn-sm">&larr; Volver</a>
</div>

<div class="card">
  <div class="card-header"><strong>Nuevo Reparto</strong></div>
  <div class="card-body">
    <% if (typeof errors.general !== 'undefined' && errors.general) { %>
      <div class="alert alert-danger"><%= errors.general %></div>
    <% } %>

    <form method="POST" action="/admin/repartos">
      <div class="mb-3">
        <label for="repartidorId" class="form-label">Repartidor</label>
        <select class="form-select" id="repartidorId" name="repartidorId" required>
          <option value="">Seleccionar repartidor...</option>
          <% repartidores.forEach(r => { %>
            <option value="<%= r.id %>"><%= r.apellido %>, <%= r.nombre %></option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label for="fecha" class="form-label">Fecha</label>
        <input type="date" class="form-control" id="fecha" name="fecha" value="<%= new Date().toISOString().slice(0, 10) %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Pedidos disponibles</label>
        <% if (pedidosDisponibles.length === 0) { %>
          <p class="text-muted">No hay pedidos pendientes sin asignar para esta fecha.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm table-bordered">
              <thead class="table-light">
                <tr>
                  <th style="width:40px">
                    <input type="checkbox" id="select-all">
                  </th>
                  <th>#</th>
                  <th>Cliente</th>
                  <th>Items</th>
                </tr>
              </thead>
              <tbody>
                <% pedidosDisponibles.forEach(p => { %>
                  <tr>
                    <td>
                      <input type="checkbox" name="pedidoIds" value="<%= p.id %>" class="pedido-check">
                    </td>
                    <td><%= p.numeroPedido %></td>
                    <td><%= p.cliente.apellido %>, <%= p.cliente.nombre %></td>
                    <td><%= p.itemsCount %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Crear Reparto</button>
        <a href="/admin/repartos" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('select-all')?.addEventListener('change', function() {
    document.querySelectorAll('.pedido-check').forEach(cb => cb.checked = this.checked);
  });
</script>

<%- include('../layouts/footer') %>
