<%- include('../layouts/header') %>

<header class="flex justify-between items-center mb-3">
  <div>
    <span class="text-muted"><%= total %> repartos</span>
  </div>
  <a href="/admin/repartos/nuevo" role="button" class="primary">Nuevo Reparto</a>
</header>

<form method="GET" class="flex gap-2 mb-3 items-center">
  <input type="date" name="fecha" value="<%= typeof filters.fecha !== 'undefined' ? filters.fecha : '' %>">
  <button type="submit" class="secondary outline">Filtrar</button>
</form>

<table>
  <thead>
    <tr>
      <th>Fecha</th>
      <th>Repartidor</th>
      <th>Estado</th>
      <th>Pedidos</th>
      <th>Completados</th>
      <th>Inicio</th>
      <th>Fin</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% repartos.forEach(r => { %>
      <tr>
        <td><%= r.fecha %></td>
        <td><%= r.repartidor.apellido %>, <%= r.repartidor.nombre %></td>
        <td>
          <span class="badge-<%= r.estado === 'COMPLETADO' ? 'success' : r.estado === 'EN_CURSO' ? 'en-curso' : 'pendiente' %>">
            <%= r.estado.replace(/_/g, ' ') %>
          </span>
        </td>
        <td><%= r.resumen.totalPedidos %></td>
        <td><%= r.resumen.completados %> / <%= r.resumen.totalPedidos %></td>
        <td><%= r.horaInicio || '-' %></td>
        <td><%= r.horaFin || '-' %></td>
        <td>
          <a href="/admin/repartos/<%= r.id %>" role="button" class="secondary outline small-btn">Ver</a>
        </td>
      </tr>
    <% }) %>
    <% if (repartos.length === 0) { %>
      <tr><td colspan="8" class="text-center text-muted" style="padding:1rem 0">No hay repartos</td></tr>
    <% } %>
  </tbody>
</table>

<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
