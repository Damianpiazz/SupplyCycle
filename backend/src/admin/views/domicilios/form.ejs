<%- include('../layouts/header') %>
<a href="/admin/domicilios" class="secondary outline small-btn mb-2">&larr; Volver</a>
<article>
  <header><strong><%= domicilio ? 'Editar' : 'Nuevo' %> Domicilio</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>
  <form method="POST" action="/admin/domicilios<%= domicilio ? '/' + domicilio.id : '' %>">
    <div class="grid" style="grid-template-columns: 2fr 1fr 1fr; gap: 1rem;">
      <label for="calle">Calle
        <input type="text" id="calle" name="calle" value="<%= domicilio ? domicilio.calle : '' %>" required>
      </label>
      <label for="numero">Número
        <input type="text" id="numero" name="numero" value="<%= domicilio ? domicilio.numero : '' %>" required>
      </label>
      <label for="piso">Piso
        <input type="text" id="piso" name="piso" value="<%= domicilio ? (domicilio.piso || '') : '' %>">
      </label>
    </div>
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="entreCalle1">Entre calle 1
        <input type="text" id="entreCalle1" name="entreCalle1" value="<%= domicilio ? (domicilio.entreCalle1 || '') : '' %>">
      </label>
      <label for="entreCalle2">Entre calle 2
        <input type="text" id="entreCalle2" name="entreCalle2" value="<%= domicilio ? (domicilio.entreCalle2 || '') : '' %>">
      </label>
    </div>
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="clienteId">Cliente
        <select id="clienteId" name="clienteId" required>
          <option value="">Seleccionar cliente...</option>
          <% clientes.forEach(c => { %>
            <option value="<%= c.id %>" <%= domicilio && domicilio.clienteId === c.id ? 'selected' : '' %>><%= c.apellido %>, <%= c.nombre %></option>
          <% }) %>
        </select>
      </label>
      <label for="ciudadId">Ciudad
        <select id="ciudadId" name="ciudadId" required>
          <option value="">Seleccionar ciudad...</option>
          <% ciudades.forEach(c => { %>
            <option value="<%= c.id %>" <%= domicilio && domicilio.ciudadId === c.id ? 'selected' : '' %>><%= c.nombre %></option>
          <% }) %>
        </select>
      </label>
    </div>
    <footer class="flex gap-2">
      <button type="submit" class="primary"><%= domicilio ? 'Guardar Cambios' : 'Crear Domicilio' %></button>
      <a href="/admin/domicilios" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>
<%- include('../layouts/footer') %>
