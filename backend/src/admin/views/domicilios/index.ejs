<%- include('../layouts/header') %>
<header class="flex justify-between items-center mb-3">
  <div><span class="text-muted"><%= total %> domicilios</span></div>
  <a href="/admin/domicilios/nuevo" role="button" class="primary">Nuevo Domicilio</a>
</header>
<form method="GET" class="flex gap-2 mb-3 items-center">
  <input type="text" name="search" placeholder="Buscar calle o número..." value="<%= search %>">
  <button type="submit" class="secondary outline">Buscar</button>
</form>
<table>
  <thead>
    <tr><th>Calle</th><th>Número</th><th>Piso</th><th>Cliente</th><th>Ciudad</th><th></th></tr>
  </thead>
  <tbody>
    <% domicilios.forEach(d => { %>
      <tr>
        <td><%= d.calle %></td>
        <td><%= d.numero %></td>
        <td><%= d.piso || '-' %></td>
        <td><%= d.cliente.apellido %>, <%= d.cliente.nombre %></td>
        <td><%= d.ciudad.nombre %></td>
        <td class="action-cell">
          <a href="/admin/domicilios/<%= d.id %>/editar" role="button" class="secondary outline small-btn">Editar</a>
          <form method="POST" action="/admin/domicilios/<%= d.id %>/eliminar" onsubmit="return confirm('¿Eliminar este domicilio?')">
            <button type="submit" class="secondary outline small-btn">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (domicilios.length === 0) { %>
      <tr><td colspan="6" class="text-center text-muted" style="padding:1rem 0">No hay domicilios</td></tr>
    <% } %>
  </tbody>
</table>
<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
