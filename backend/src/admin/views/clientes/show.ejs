<%- include('../layouts/header') %>

<a href="/admin/clientes" class="secondary outline small-btn" style="margin-bottom:1rem;display:inline-block;">&larr; Volver</a>

<article style="margin-bottom:1rem;">
  <header class="flex justify-between items-center">
    <span><strong><%= cliente.apellido %>, <%= cliente.nombre %></strong></span>
    <span class="<%= cliente.activo ? 'badge-activo' : 'badge-inactivo' %>" style="font-size:1rem;"><%= cliente.activo ? 'Activo' : 'Inactivo' %></span>
  </header>
  <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
    <div>
      <h6>Contacto</h6>
      <p style="margin-bottom:0.25rem;">Teléfono: <strong><%= cliente.telefono %></strong></p>
    </div>
    <div>
      <h6>Dirección</h6>
      <% const dom = cliente.domicilios?.[0]; %>
      <p style="margin-bottom:0.25rem;"><%= dom?.calle ?? '' %> <%= dom?.numero ?? '' %></p>
      <p style="margin-bottom:0.25rem;"><%= dom?.localidad ?? '' %></p>
    </div>
  </div>
  <hr>
  <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
    <div>
      <h6>Horarios de entrega</h6>
      <% const dia = dom?.dias?.[0]; %>
      <% const horario = dia?.horarios?.[0]; %>
      <p style="margin-bottom:0.25rem;">Día: <strong><%= dia?.nombre ? dia.nombre.charAt(0).toUpperCase() + dia.nombre.slice(1).toLowerCase() : '-' %></strong></p>
      <p style="margin-bottom:0.25rem;">Horario: <strong><%= horario?.inicio ?? '-' %> - <%= horario?.fin ?? '-' %></strong></p>
    </div>
    <div>
      <h6>Observaciones</h6>
      <p><%= cliente.observaciones || 'Sin observaciones' %></p>
    </div>
  </div>
</article>

<% if (typeof saldoEnvases !== 'undefined' && saldoEnvases.length > 0) { %>
<article style="margin-bottom:1rem;">
  <header>
    <strong>Saldo de Envases Pendientes</strong>
  </header>
  <table>
    <thead><tr><th>Tipo de Envase</th><th>Cantidad Pendiente</th></tr></thead>
    <tbody>
      <% saldoEnvases.forEach(s => { %>
        <tr><td><%= s.itemNombre %></td><td><%= s.cantidad %></td></tr>
      <% }) %>
    </tbody>
  </table>
</article>
<% } %>

<% if (typeof retenidos !== 'undefined' && retenidos.length > 0) { %>
<article style="margin-bottom:1rem;">
  <header>
    <strong>Historial de Envases</strong>
  </header>
  <table>
    <thead><tr><th>Tipo de Envase</th><th>Fecha de Entrega</th><th>Fecha de Devolución</th><th>Estado</th><th>Pedido</th></tr></thead>
    <tbody>
      <% retenidos.forEach(r => { %>
        <tr>
          <td><%= r.item.nombre %></td>
          <td><%= r.inicio.toLocaleDateString() %></td>
          <td><%= r.fin ? r.fin.toLocaleDateString() : '-' %></td>
          <td>
            <span class="<%= r.estado === 'RETENIDO' ? 'badge-pendiente' : (r.estado === 'DEVUELTO' ? 'badge-success' : 'badge-danger') %>" style="font-size:1rem;">
              <%= r.estado.charAt(0) + r.estado.slice(1).toLowerCase() %>
            </span>
          </td>
          <td><%= r.pedido.numeroPedido %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</article>
<% } %>

<footer class="flex gap-2">
  <a href="/admin/clientes/<%= cliente.id %>/editar" role="button" class="primary">Editar</a>
  <% if (cliente.activo) { %>
    <form method="POST" action="/admin/clientes/<%= cliente.id %>/eliminar" data-confirm="¿Desactivar este cliente?">
      <button type="submit" class="primary outline">Desactivar</button>
    </form>
  <% } %>
</footer>

<%- include('../layouts/footer') %>
