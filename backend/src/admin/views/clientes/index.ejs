<%- include('../layouts/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <span class="text-muted"><%= clientes.length %> clientes</span>
  </div>
  <a href="/admin/clientes/nuevo" class="btn btn-primary">Nuevo Cliente</a>
</div>

<form method="GET" class="row g-2 mb-3">
  <div class="col-auto">
    <input type="text" class="form-control form-control-sm" name="nombre" placeholder="Buscar nombre..." value="<%= typeof filters.nombre !== 'undefined' ? filters.nombre : '' %>">
  </div>
  <div class="col-auto">
    <select class="form-select form-select-sm" name="dia">
      <option value="">Todos los días</option>
      <% diasSemana.forEach(d => { %>
        <option value="<%= d %>" <%= filters.dia === d ? 'selected' : '' %>><%= d.charAt(0).toUpperCase() + d.slice(1) %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-outline-secondary btn-sm">Filtrar</button>
  </div>
</form>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th>Apellido</th>
        <th>Nombre</th>
        <th>Teléfono</th>
        <th>Dirección</th>
        <th>Día Entrega</th>
        <th>Estado</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% clientes.forEach(c => { %>
        <tr>
          <td><%= c.apellido %></td>
          <td><%= c.nombre %></td>
          <td><%= c.telefono %></td>
          <td><%= c.domicilio.calle %> <%= c.domicilio.numero %></td>
          <td><%= c.diaEntrega ? c.diaEntrega.charAt(0).toUpperCase() + c.diaEntrega.slice(1) : '-' %></td>
          <td>
            <span class="badge bg-<%= c.activo ? 'success' : 'danger' %>"><%= c.activo ? 'Activo' : 'Inactivo' %></span>
          </td>
          <td>
            <a href="/admin/clientes/<%= c.id %>" class="btn btn-sm btn-outline-primary">Ver</a>
          </td>
        </tr>
      <% }) %>
      <% if (clientes.length === 0) { %>
        <tr><td colspan="7" class="text-center text-muted py-4">No hay clientes</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../layouts/footer') %>
