<%- include('../layouts/header') %>

<header class="flex justify-between items-center mb-3">
  <div>
    <span class="text-muted"><%= total %> clientes</span>
  </div>
  <a href="/admin/clientes/nuevo" role="button" class="primary">Nuevo Cliente</a>
</header>

<form method="GET" class="flex gap-2 mb-3 items-center">
  <input type="text" name="nombre" placeholder="Buscar nombre..." value="<%= typeof filters.nombre !== 'undefined' ? filters.nombre : '' %>">
  <select name="dia" style="width:auto">
    <option value="">Todos los días</option>
    <% diasSemana.forEach(d => { %>
      <option value="<%= d %>" <%= filters.dia === d ? 'selected' : '' %>><%= d.charAt(0).toUpperCase() + d.slice(1) %></option>
    <% }) %>
  </select>
  <button type="submit" class="secondary outline">Filtrar</button>
</form>

<table>
  <thead>
    <tr>
      <th>Apellido</th>
      <th>Nombre</th>
      <th>Teléfono</th>
      <th>Dirección</th>
      <th>Día Entrega</th>
      <th>Estado</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% clientes.forEach(c => { %>
      <tr>
        <td><%= c.apellido %></td>
        <td><%= c.nombre %></td>
        <td><%= c.telefono %></td>
        <td><%= c.domicilio.calle %> <%= c.domicilio.numero %></td>
        <td><%= c.diaEntrega ? c.diaEntrega.charAt(0).toUpperCase() + c.diaEntrega.slice(1) : '-' %></td>
        <td>
          <span class="badge-<%= c.activo ? 'activo' : 'inactivo' %>"><%= c.activo ? 'Activo' : 'Inactivo' %></span>
        </td>
        <td>
          <a href="/admin/clientes/<%= c.id %>" role="button" class="secondary outline small-btn">Ver</a>
        </td>
      </tr>
    <% }) %>
    <% if (clientes.length === 0) { %>
      <tr><td colspan="7" class="text-center text-muted" style="padding:1rem 0">No hay clientes</td></tr>
    <% } %>
  </tbody>
</table>

<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
