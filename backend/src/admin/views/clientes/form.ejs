<%- include('../layouts/header') %>

<div class="mb-3">
  <a href="/admin/clientes" class="btn btn-outline-secondary btn-sm">&larr; Volver</a>
</div>

<div class="card">
  <div class="card-header"><strong><%= cliente ? 'Editar' : 'Nuevo' %> Cliente</strong></div>
  <div class="card-body">
    <% if (typeof errors.general !== 'undefined' && errors.general) { %>
      <div class="alert alert-danger"><%= errors.general %></div>
    <% } %>

    <form method="POST" action="/admin/clientes<%= cliente ? '/' + cliente.id : '' %>">
      <div class="row mb-3">
        <div class="col-md-6">
          <label for="nombre" class="form-label">Nombre</label>
          <input type="text" class="form-control" id="nombre" name="nombre" value="<%= cliente ? cliente.nombre : '' %>" required>
        </div>
        <div class="col-md-6">
          <label for="apellido" class="form-label">Apellido</label>
          <input type="text" class="form-control" id="apellido" name="apellido" value="<%= cliente ? cliente.apellido : '' %>" required>
        </div>
      </div>

      <div class="mb-3">
        <label for="telefono" class="form-label">Teléfono</label>
        <input type="text" class="form-control" id="telefono" name="telefono" value="<%= cliente ? cliente.telefono : '' %>" required>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label for="calle" class="form-label">Calle</label>
          <input type="text" class="form-control" id="calle" name="calle" value="<%= cliente ? cliente.domicilio.calle : '' %>" required>
        </div>
        <div class="col-md-2">
          <label for="numero" class="form-label">Número</label>
          <input type="text" class="form-control" id="numero" name="numero" value="<%= cliente ? cliente.domicilio.numero : '' %>" required>
        </div>
        <div class="col-md-4">
          <label for="localidad" class="form-label">Localidad</label>
          <input type="text" class="form-control" id="localidad" name="localidad" value="<%= cliente ? cliente.domicilio.localidad : '' %>" required>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-3">
          <label for="latitud" class="form-label">Latitud</label>
          <input type="number" step="any" class="form-control" id="latitud" name="latitud" value="<%= cliente ? cliente.domicilio.latitud : '' %>">
        </div>
        <div class="col-md-3">
          <label for="longitud" class="form-label">Longitud</label>
          <input type="number" step="any" class="form-control" id="longitud" name="longitud" value="<%= cliente ? cliente.domicilio.longitud : '' %>">
        </div>
        <div class="col-md-3">
          <label for="diaEntrega" class="form-label">Día de entrega</label>
          <select class="form-select" id="diaEntrega" name="diaEntrega">
            <option value="">Seleccionar...</option>
            <% diasSemana.forEach(d => { %>
              <option value="<%= d %>" <%= cliente && cliente.diaEntrega === d ? 'selected' : '' %>><%= d.charAt(0).toUpperCase() + d.slice(1) %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-3">
          <label for="horarioDesde" class="form-label">Horario desde</label>
          <input type="time" class="form-control" id="horarioDesde" name="horarioDesde" value="<%= cliente ? cliente.horarioDesde : '' %>">
        </div>
        <div class="col-md-3">
          <label for="horarioHasta" class="form-label">Horario hasta</label>
          <input type="time" class="form-control" id="horarioHasta" name="horarioHasta" value="<%= cliente ? cliente.horarioHasta : '' %>">
        </div>
      </div>

      <div class="mb-3">
        <label for="observaciones" class="form-label">Observaciones</label>
        <textarea class="form-control" id="observaciones" name="observaciones" rows="2"><%= cliente ? (cliente.observaciones || '') : '' %></textarea>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><%= cliente ? 'Guardar Cambios' : 'Crear Cliente' %></button>
        <a href="/admin/clientes" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../layouts/footer') %>
