<%- include('../layouts/header') %>

<a href="/admin/clientes" class="secondary outline small-btn mb-2">&larr; Volver</a>

<article>
  <header><strong><%= cliente ? 'Editar' : 'Nuevo' %> Cliente</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>

  <form method="POST" action="/admin/clientes<%= cliente ? '/' + cliente.id : '' %>">
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="nombre">Nombre
        <input type="text" id="nombre" name="nombre" value="<%= cliente ? cliente.nombre : '' %>" required>
      </label>
      <label for="apellido">Apellido
        <input type="text" id="apellido" name="apellido" value="<%= cliente ? cliente.apellido : '' %>" required>
      </label>
    </div>

    <label for="telefono">Teléfono
      <input type="text" id="telefono" name="telefono" value="<%= cliente ? cliente.telefono : '' %>" required>
    </label>

    <div class="grid" style="grid-template-columns: 3fr 1fr 2fr; gap: 1rem;">
      <label for="calle">Calle
        <input type="text" id="calle" name="calle" value="<%= cliente ? cliente.domicilio.calle : '' %>" required>
      </label>
      <label for="numero">Número
        <input type="text" id="numero" name="numero" value="<%= cliente ? cliente.domicilio.numero : '' %>" required>
      </label>
      <label for="localidad">Localidad
        <input type="text" id="localidad" name="localidad" value="<%= cliente ? cliente.domicilio.localidad : '' %>" required>
      </label>
    </div>

    <div class="grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
      <label for="latitud">Latitud
        <input type="number" step="any" id="latitud" name="latitud" value="<%= cliente ? cliente.domicilio.latitud : '' %>">
      </label>
      <label for="longitud">Longitud
        <input type="number" step="any" id="longitud" name="longitud" value="<%= cliente ? cliente.domicilio.longitud : '' %>">
      </label>
      <label for="diaEntrega">Día de entrega
        <select id="diaEntrega" name="diaEntrega">
          <option value="">Seleccionar...</option>
          <% diasSemana.forEach(d => { %>
            <option value="<%= d %>" <%= cliente && cliente.diaEntrega === d ? 'selected' : '' %>><%= d.charAt(0).toUpperCase() + d.slice(1) %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="horarioDesde">Horario desde
        <input type="time" id="horarioDesde" name="horarioDesde" value="<%= cliente ? cliente.horarioDesde : '' %>">
      </label>
      <label for="horarioHasta">Horario hasta
        <input type="time" id="horarioHasta" name="horarioHasta" value="<%= cliente ? cliente.horarioHasta : '' %>">
      </label>
    </div>

    <label for="observaciones">Observaciones
      <textarea id="observaciones" name="observaciones" rows="2"><%= cliente ? (cliente.observaciones || '') : '' %></textarea>
    </label>

    <footer class="flex gap-2">
      <button type="submit" class="primary"><%= cliente ? 'Guardar Cambios' : 'Crear Cliente' %></button>
      <a href="/admin/clientes" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>

<%- include('../layouts/footer') %>
