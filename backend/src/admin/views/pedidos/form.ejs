<%- include('../layouts/header') %>

<a href="/admin/pedidos" class="secondary outline small-btn mb-2">&larr; Volver</a>

<article>
  <header><strong><%= pedido ? 'Editar' : 'Nuevo' %> Pedido</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>

  <form method="POST" action="/admin/pedidos<%= pedido ? '/' + pedido.id : '' %>">
    <label for="clienteId">Cliente
      <select id="clienteId" name="clienteId" <%= pedido ? 'disabled' : '' %>>
        <option value="">Seleccionar cliente...</option>
        <% clientes.forEach(c => { %>
          <option value="<%= c.id %>" <%= pedido && pedido.cliente.id === c.id ? 'selected' : '' %>><%= c.apellido %>, <%= c.nombre %> — <%= c.telefono %></option>
        <% }) %>
      </select>
    </label>

    <% if (!pedido) { %>
      <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
        <label for="fecha">Fecha
          <input type="date" id="fecha" name="fecha" value="<%= new Date().toISOString().slice(0, 10) %>">
        </label>
        <label for="orden">Orden (opcional)
          <input type="number" id="orden" name="orden" min="1">
        </label>
      </div>
    <% } %>

    <label>Items</label>
    <div id="items-container">
      <% if (pedido) { %>
        <% pedido.items.forEach((item, idx) => { %>
          <div class="flex gap-2 items-center" style="margin-bottom: 0.5rem;">
            <div style="flex:6">
              <input type="text" value="<%= item.item.nombre %>" readonly>
              <input type="hidden" name="items[<%= idx %>][id]" value="<%= item.id %>">
            </div>
            <div style="flex:3">
              <input type="number" name="items[<%= idx %>][cantidad]" value="<%= item.cantidad %>" min="1" required>
            </div>
            <div style="flex:2"><small><%= item.item.unidad %></small></div>
            <div style="flex:1">
              <a href="/admin/pedidos/<%= pedido.id %>/items/<%= item.id %>/quitar" class="secondary outline small-btn" onclick="return confirm('¿Quitar este item?')">Quitar</a>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="flex gap-2 items-center item-row" style="margin-bottom: 0.5rem;">
          <div style="flex:6">
            <select name="items[0][itemId]" required>
              <option value="">Seleccionar item...</option>
              <% items.forEach(item => { %>
                <option value="<%= item.id %>"><%= item.nombre %> ($<%= item.precio?.toFixed(2) %>)</option>
              <% }) %>
            </select>
          </div>
          <div style="flex:3">
            <input type="number" name="items[0][cantidad]" placeholder="Cantidad" min="1" required>
          </div>
          <div style="flex:2"></div>
          <div style="flex:1">
            <button type="button" class="secondary outline small-btn remove-item">X</button>
          </div>
        </div>
      <% } %>
    </div>
    <% if (!pedido) { %>
      <button type="button" class="secondary outline small-btn mt-1" id="add-item">+ Agregar otro item</button>
    <% } %>
    <% if (pedido && pedido.estado === 'PENDIENTE') { %>
      <hr>
      <div class="flex gap-2 items-center">
        <div style="flex:6">
          <select name="nuevoItemId">
            <option value="">Agregar nuevo item...</option>
            <% items.forEach(item => { %>
              <option value="<%= item.id %>"><%= item.nombre %></option>
            <% }) %>
          </select>
        </div>
        <div style="flex:3">
          <input type="number" name="nuevaCantidad" placeholder="Cantidad" min="1">
        </div>
      </div>
    <% } %>

    <footer class="flex gap-2">
      <button type="submit" class="primary"><%= pedido ? 'Guardar Cambios' : 'Crear Pedido' %></button>
      <a href="/admin/pedidos" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>

<% if (!pedido) { %>
<script>
  let itemIdx = 1;
  document.getElementById('add-item')?.addEventListener('click', function() {
    const container = document.getElementById('items-container');
    const row = container.querySelector('.item-row').cloneNode(true);
    row.querySelectorAll('[name]').forEach(el => {
      el.name = el.name.replace(/\[\d+\]/, '[' + itemIdx + ']');
      el.value = '';
    });
    row.querySelector('.remove-item').addEventListener('click', function() {
      row.remove();
    });
    container.appendChild(row);
    itemIdx++;
  });
  document.querySelectorAll('.remove-item').forEach(btn => {
    btn.addEventListener('click', function() {
      if (document.querySelectorAll('.item-row').length > 1) {
        this.closest('.item-row').remove();
      }
    });
  });
</script>
<% } %>
<%- include('../layouts/footer') %>
