<%- include('../layouts/header') %>

<a href="/admin/pedidos" class="secondary outline small-btn" style="margin-bottom:1rem;display:inline-block;">&larr; Volver</a>

<article style="margin-bottom:1rem;">
  <header class="flex justify-between items-center">
    <span><strong>Pedido #<%= pedido.numeroPedido %></strong></span>
    <span class="<%= pedido.estado === 'ENTREGADO' ? 'badge-entregado' : (pedido.estado === 'CANCELADO' || pedido.estado === 'NO_ENTREGADO') ? 'badge-no-entregado' : pedido.estado === 'EN_RUTA' ? 'badge-en-curso' : 'badge-pendiente' %>" style="font-size:1rem;">
      <%= pedido.estado.replace(/_/g, ' ') %>
    </span>
  </header>
  <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
    <div>
      <h6>Cliente</h6>
      <p style="margin-bottom:0.25rem;"><strong><%= pedido.cliente.apellido %>, <%= pedido.cliente.nombre %></strong></p>
      <p style="margin-bottom:0.25rem;">Tel: <%= pedido.cliente.telefono %></p>
      <p style="margin-bottom:0.25rem;">Dirección: <%= pedido.domicilio.calle %> <%= pedido.domicilio.numero %>, <%= pedido.domicilio.localidad %></p>
      <p style="margin-bottom:0.25rem;">Día de entrega: <%= pedido.domicilio.dias?.[0]?.nombre ?? '-' %></p>
      <p>Horario: <%= pedido.domicilio.dias?.[0]?.horarios?.[0]?.inicio ?? '-' %> - <%= pedido.domicilio.dias?.[0]?.horarios?.[0]?.fin ?? '-' %></p>
    </div>
    <div>
      <h6>Detalles</h6>
      <p style="margin-bottom:0.25rem;">Fecha: <%= pedido.fecha %></p>
      <p style="margin-bottom:0.25rem;">Orden: <%= pedido.orden %></p>
      <p>Total: <strong>$<%= pedido.total?.toFixed(2) %></strong></p>
    </div>
  </div>
</article>

<article style="margin-bottom:1rem;">
  <header class="flex justify-between items-center">
    <span><strong>Items</strong></span>
    <span class="badge-secondary" style="font-size:1rem;"><%= pedido.items.length %> items</span>
  </header>
  <table>
    <thead>
      <tr>
        <th>Item</th>
        <th>Cantidad</th>
        <th>Precio Unit.</th>
        <th>Subtotal</th>
        <% if (pedido.estado === 'PENDIENTE') { %>
          <th></th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <% pedido.items.forEach(item => { %>
        <tr>
          <td><%= item.item.nombre %></td>
          <td><%= item.cantidad %> <%= item.item.unidad %></td>
          <td>$<%= item.precioUnitario?.toFixed(2) %></td>
          <td>$<%= (item.cantidad * (item.precioUnitario || 0)).toFixed(2) %></td>
          <% if (pedido.estado === 'PENDIENTE') { %>
            <td>
              <form method="POST" action="/admin/pedidos/<%= pedido.id %>/items/<%= item.id %>/quitar" data-confirm="¿Quitar este item?" class="flex">
                <button type="submit" class="primary outline small-btn">Quitar</button>
              </form>
            </td>
          <% } %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</article>

<% if (pedido.estado === 'PENDIENTE') { %>
  <article style="margin-bottom:1rem;">
    <header><strong>Agregar Item</strong></header>
    <form method="POST" action="/admin/pedidos/<%= pedido.id %>" class="flex gap-2 items-center">
      <a href="/admin/pedidos/<%= pedido.id %>/editar" class="primary outline">Editar Pedido</a>
    </form>
  </article>
<% } %>

<footer class="flex gap-2">
  <% if (pedido.estado === 'PENDIENTE') { %>
    <form method="POST" action="/admin/pedidos/<%= pedido.id %>/cancelar" data-confirm="¿Cancelar este pedido?">
      <button type="submit" class="primary outline">Cancelar Pedido</button>
    </form>
    <form method="POST" action="/admin/pedidos/<%= pedido.id %>/eliminar" data-confirm="¿Eliminar este pedido?">
      <button type="submit" class="primary outline">Eliminar</button>
    </form>
  <% } %>
</footer>

<%- include('../layouts/footer') %>
