<%- include('../layouts/header') %>
<div class="mb-3">
  <a href="/admin/empleados" class="btn btn-outline-secondary btn-sm">&larr; Volver</a>
</div>
<div class="card">
  <div class="card-header"><strong><%= empleado ? 'Editar' : 'Nuevo' %> Empleado</strong></div>
  <div class="card-body">
    <% if (typeof errors.general !== 'undefined' && errors.general) { %>
      <div class="alert alert-danger"><%= errors.general %></div>
    <% } %>
    <form method="POST" action="/admin/empleados<%= empleado ? '/' + empleado.id : '' %>">
      <div class="row mb-3">
        <div class="col-md-6">
          <label for="apellido" class="form-label">Apellido</label>
          <input type="text" class="form-control" id="apellido" name="apellido" value="<%= empleado ? empleado.apellido : '' %>" required>
        </div>
        <div class="col-md-6">
          <label for="nombre" class="form-label">Nombre</label>
          <input type="text" class="form-control" id="nombre" name="nombre" value="<%= empleado ? empleado.nombre : '' %>" required>
        </div>
      </div>
      <div class="mb-3">
        <label for="dni" class="form-label">DNI</label>
        <input type="text" class="form-control" id="dni" name="dni" value="<%= empleado ? empleado.dni : '' %>" required>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><%= empleado ? 'Guardar Cambios' : 'Crear Empleado' %></button>
        <a href="/admin/empleados" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
<%- include('../layouts/footer') %>
