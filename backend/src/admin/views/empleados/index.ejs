<%- include('../layouts/header') %>
<header class="flex justify-between items-center mb-3">
  <div><span class="text-muted"><%= empleados.length %> empleados</span></div>
  <a href="/admin/empleados/nuevo" role="button" class="primary">Nuevo Empleado</a>
</header>
<form method="GET" class="flex gap-2 mb-3 items-center">
  <input type="text" name="search" placeholder="Buscar nombre, apellido o DNI..." value="<%= search %>">
  <button type="submit" class="secondary outline">Buscar</button>
</form>
<table>
  <thead>
    <tr><th>Apellido</th><th>Nombre</th><th>DNI</th><th></th></tr>
  </thead>
  <tbody>
    <% empleados.forEach(e => { %>
      <tr>
        <td><%= e.apellido %></td>
        <td><%= e.nombre %></td>
        <td><%= e.dni %></td>
        <td class="action-cell">
          <a href="/admin/empleados/<%= e.id %>/editar" role="button" class="secondary outline small-btn">Editar</a>
          <form method="POST" action="/admin/empleados/<%= e.id %>/eliminar" onsubmit="return confirm('¿Eliminar este empleado?')">
            <button type="submit" class="secondary outline small-btn">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (empleados.length === 0) { %>
      <tr><td colspan="4" class="text-center text-muted" style="padding:1rem 0">No hay empleados</td></tr>
    <% } %>
  </tbody>
</table>
<%- include('../layouts/footer') %>
