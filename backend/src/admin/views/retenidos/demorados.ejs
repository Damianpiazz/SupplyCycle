<%- include('../layouts/header') %>

<header class="flex justify-between items-center mb-3">
  <span><%= demorados.length %> clientes con envases demorados (&gt; <%= DIAS_LIMITE_DEMORA %> días)</span>
</header>

<form method="GET" class="flex gap-2 mb-3 items-center">
  <input type="text" name="nombre" placeholder="Buscar por nombre o apellido" value="<%= filtroNombre %>">
  <button class="secondary outline">Buscar</button>
  <% if (filtroNombre) { %>
    <a href="/admin/retenidos/demorados" class="secondary outline">Limpiar</a>
  <% } %>
</form>

<table>
  <thead>
    <tr>
      <th>Cliente</th>
      <th>Teléfono</th>
      <th>Envases Pendientes</th>
      <th>Última Entrega</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% demorados.forEach(d => { %>
      <tr>
        <td><%= d.apellido %>, <%= d.nombre %></td>
        <td>
          <a href="https://wa.me/<%= d.telefono %>" target="_blank" rel="noopener noreferrer">
            <%= d.telefono %>
          </a>
        </td>
        <td><%= d.cantidadPendientes %></td>
        <td><%= d.ultimaEntrega ? d.ultimaEntrega.toLocaleDateString() : '-' %></td>
        <td>
          <a href="/admin/clientes/<%= d.id %>" class="primary outline small-btn">Ver Detalle</a>
        </td>
      </tr>
    <% }) %>
    <% if (demorados.length === 0) { %>
      <tr><td colspan="5" style="text-align:center; padding:1rem 0;">No hay clientes con envases demorados</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('../layouts/footer') %>
