<%- include('../layouts/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <span class="text-muted"><%= demorados.length %> clientes con envases demorados (&gt; <%= DIAS_LIMITE_DEMORA %> días)</span>
  </div>
</div>

<form method="GET" class="row g-2 mb-3">
  <div class="col-auto">
    <input type="text" class="form-control form-control-sm" name="nombre" placeholder="Buscar por nombre o apellido" value="<%= filtroNombre %>">
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-outline-secondary btn-sm">Buscar</button>
    <% if (filtroNombre) { %>
      <a href="/admin/retenidos/demorados" class="btn btn-outline-danger btn-sm">Limpiar</a>
    <% } %>
  </div>
</form>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th>Cliente</th>
        <th>Teléfono</th>
        <th>Envases Pendientes</th>
        <th>Última Entrega</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% demorados.forEach(d => { %>
        <tr>
          <td><%= d.apellido %>, <%= d.nombre %></td>
          <td>
            <a href="https://wa.me/<%= d.telefono %>" target="_blank" rel="noopener noreferrer">
              <%= d.telefono %>
            </a>
          </td>
          <td><%= d.cantidadPendientes %></td>
          <td><%= d.ultimaEntrega ? d.ultimaEntrega.toLocaleDateString() : '-' %></td>
          <td>
            <a href="/admin/clientes/<%= d.id %>" class="btn btn-sm btn-outline-primary">Ver Detalle</a>
          </td>
        </tr>
      <% }) %>
      <% if (demorados.length === 0) { %>
        <tr><td colspan="5" class="text-center text-muted py-4">No hay clientes con envases demorados</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../layouts/footer') %>
