<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SupplyCycle Admin — Iniciar Sesión</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
  <link href="/static/css/supplycycle-theme.css" rel="stylesheet">
  <style>
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--pico-background-color);
      margin: 0;
    }
    article { max-width: 400px; width: 100%; }
  </style>
</head>
<body>
  <article>
    <header style="text-align:center;">
      <h4 style="margin:0;">SupplyCycle Admin</h4>
    </header>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" role="alert"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login">
      <label for="email">Email
        <input type="email" id="email" name="email" required autocomplete="email">
      </label>
      <label for="password">Contraseña
        <input type="password" id="password" name="password" required autocomplete="current-password">
      </label>
      <button type="submit" class="primary" style="width:100%;margin-top:0.5rem;">Ingresar</button>
    </form>
  </article>
</body>
</html>
