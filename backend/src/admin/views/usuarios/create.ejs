<%- include('../layouts/header') %>

<a href="/admin/usuarios" class="secondary outline small-btn mb-2">&larr; Volver</a>

<article>
  <header><strong>Nuevo Usuario</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>

  <form method="POST" action="/admin/usuarios">
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="nombre">Nombre
        <input type="text" id="nombre" name="nombre" required>
      </label>
      <label for="apellido">Apellido
        <input type="text" id="apellido" name="apellido" required>
      </label>
    </div>

    <label for="email">Email
      <input type="email" id="email" name="email" required>
    </label>

    <label for="password">Contraseña
      <input type="password" id="password" name="password" required minlength="8">
    </label>

    <label for="rol">Rol
      <select id="rol" name="rol">
        <option value="REPARTIDOR">Repartidor</option>
        <option value="ADMIN">Administrador</option>
      </select>
    </label>

    <footer class="flex gap-2">
      <button type="submit" class="primary">Crear Usuario</button>
      <a href="/admin/usuarios" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>

<%- include('../layouts/footer') %>
