<%- include('../layouts/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <span class="text-muted"><%= usuarios.length %> usuarios</span>
  </div>
  <a href="/admin/usuarios/nuevo" class="btn btn-primary">Nuevo Usuario</a>
</div>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th>Apellido</th>
        <th>Nombre</th>
        <th>Email</th>
        <th>Rol</th>
        <th>Estado</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% usuarios.forEach(u => { %>
        <tr>
          <td><%= u.apellido %></td>
          <td><%= u.nombre %></td>
          <td><%= u.email %></td>
          <td>
            <span class="badge bg-<%= u.rol === 'ADMIN' ? 'info' : 'secondary' %>"><%= u.rol %></span>
          </td>
          <td>
            <span class="badge bg-<%= u.activo ? 'success' : 'danger' %>"><%= u.activo ? 'Activo' : 'Inactivo' %></span>
          </td>
          <td>
            <% if (u.activo) { %>
              <form method="POST" action="/admin/usuarios/<%= u.id %>/desactivar" data-confirm="¿Desactivar este usuario?" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-danger">Desactivar</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
      <% if (usuarios.length === 0) { %>
        <tr><td colspan="6" class="text-center text-muted py-4">No hay usuarios</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../layouts/footer') %>
