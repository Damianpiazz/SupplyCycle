<%- include('../layouts/header') %>

<header class="flex justify-between items-center mb-3">
  <div>
    <span class="text-muted"><%= usuarios.length %> usuarios</span>
  </div>
  <a href="/admin/usuarios/nuevo" role="button" class="primary">Nuevo Usuario</a>
</header>

<table>
  <thead>
    <tr>
      <th>Apellido</th>
      <th>Nombre</th>
      <th>Email</th>
      <th>Rol</th>
      <th>Estado</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% usuarios.forEach(u => { %>
      <tr>
        <td><%= u.apellido %></td>
        <td><%= u.nombre %></td>
        <td><%= u.email %></td>
        <td>
          <span class="badge-<%= u.rol === 'ADMIN' ? 'en-curso' : 'secondary' %>"><%= u.rol %></span>
        </td>
        <td>
          <span class="badge-<%= u.activo ? 'activo' : 'inactivo' %>"><%= u.activo ? 'Activo' : 'Inactivo' %></span>
        </td>
        <td>
          <% if (u.activo) { %>
            <form method="POST" action="/admin/usuarios/<%= u.id %>/desactivar" data-confirm="¿Desactivar este usuario?">
              <button type="submit" class="secondary outline small-btn">Desactivar</button>
            </form>
          <% } %>
        </td>
      </tr>
    <% }) %>
    <% if (usuarios.length === 0) { %>
      <tr><td colspan="6" class="text-center text-muted" style="padding:1rem 0">No hay usuarios</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('../layouts/footer') %>
