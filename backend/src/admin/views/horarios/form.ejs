<%- include('../layouts/header') %>
<a href="/admin/horarios" class="secondary outline small-btn mb-2">&larr; Volver</a>
<article>
  <header><strong><%= horario ? 'Editar' : 'Nuevo' %> Horario</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>
  <form method="POST" action="/admin/horarios<%= horario ? '/' + horario.id : '' %>">
    <label for="diaId">Día
      <select id="diaId" name="diaId" required>
        <option value="">Seleccionar día...</option>
        <% dias.forEach(d => { %>
          <option value="<%= d.id %>" <%= horario && horario.diaId === d.id ? 'selected' : '' %>><%= d.nombre.charAt(0) + d.nombre.slice(1).toLowerCase() %> — <%= d.domicilio.cliente.apellido %>, <%= d.domicilio.cliente.nombre %></option>
        <% }) %>
      </select>
    </label>
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="inicio">Inicio
        <input type="datetime-local" id="inicio" name="inicio" value="<%= horario ? new Date(horario.inicio.getTime() - horario.inicio.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>" required>
      </label>
      <label for="fin">Fin
        <input type="datetime-local" id="fin" name="fin" value="<%= horario ? new Date(horario.fin.getTime() - horario.fin.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>" required>
      </label>
    </div>
    <footer class="flex gap-2">
      <button type="submit" class="primary"><%= horario ? 'Guardar Cambios' : 'Crear Horario' %></button>
      <a href="/admin/horarios" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>
<%- include('../layouts/footer') %>
