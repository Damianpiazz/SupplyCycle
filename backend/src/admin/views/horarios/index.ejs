<%- include('../layouts/header') %>
<header class="flex justify-between items-center mb-3">
  <div><span class="text-muted"><%= total %> horarios</span></div>
  <a href="/admin/horarios/nuevo" role="button" class="primary">Nuevo Horario</a>
</header>
<form method="GET" class="flex gap-2 mb-3 items-center">
  <select name="diaId" style="width:auto">
    <option value="">Todos</option>
    <% dias.forEach(d => { %>
      <option value="<%= d.id %>" <%= diaId === d.id ? 'selected' : '' %>><%= d.nombre.charAt(0) + d.nombre.slice(1).toLowerCase() %> — <%= d.domicilio.cliente.apellido %>, <%= d.domicilio.cliente.nombre %></option>
    <% }) %>
  </select>
  <button type="submit" class="secondary outline">Filtrar</button>
</form>
<table>
  <thead>
    <tr><th>Inicio</th><th>Fin</th><th>Día</th><th>Cliente</th><th></th></tr>
  </thead>
  <tbody>
    <% horarios.forEach(h => { %>
      <tr>
        <td><%= h.inicio.toLocaleTimeString() %></td>
        <td><%= h.fin.toLocaleTimeString() %></td>
        <td><%= h.dia.nombre.charAt(0) + h.dia.nombre.slice(1).toLowerCase() %></td>
        <td><%= h.dia.domicilio.cliente.apellido %>, <%= h.dia.domicilio.cliente.nombre %></td>
        <td class="action-cell">
          <a href="/admin/horarios/<%= h.id %>/editar" role="button" class="secondary outline small-btn">Editar</a>
          <form method="POST" action="/admin/horarios/<%= h.id %>/eliminar" onsubmit="return confirm('¿Eliminar este horario?')">
            <button type="submit" class="secondary outline small-btn">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (horarios.length === 0) { %>
      <tr><td colspan="5" class="text-center text-muted" style="padding:1rem 0">No hay horarios</td></tr>
    <% } %>
  </tbody>
</table>
<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
