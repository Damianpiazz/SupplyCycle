<%- include('../layouts/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><span class="text-muted"><%= total %> horarios</span></div>
  <a href="/admin/horarios/nuevo" class="btn btn-primary">Nuevo Horario</a>
</div>
<form method="GET" class="row g-2 mb-3">
  <div class="col-auto">
    <select class="form-select form-select-sm" name="diaId">
      <option value="">Todos</option>
      <% dias.forEach(d => { %>
        <option value="<%= d.id %>" <%= diaId === d.id ? 'selected' : '' %>><%= d.nombre.charAt(0) + d.nombre.slice(1).toLowerCase() %> — <%= d.domicilio.cliente.apellido %>, <%= d.domicilio.cliente.nombre %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-outline-secondary btn-sm">Filtrar</button>
  </div>
</form>
<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr><th>Inicio</th><th>Fin</th><th>Día</th><th>Cliente</th><th></th></tr>
    </thead>
    <tbody>
      <% horarios.forEach(h => { %>
        <tr>
          <td><%= h.inicio.toLocaleTimeString() %></td>
          <td><%= h.fin.toLocaleTimeString() %></td>
          <td><%= h.dia.nombre.charAt(0) + h.dia.nombre.slice(1).toLowerCase() %></td>
          <td><%= h.dia.domicilio.cliente.apellido %>, <%= h.dia.domicilio.cliente.nombre %></td>
          <td>
            <a href="/admin/horarios/<%= h.id %>/editar" class="btn btn-sm btn-outline-primary">Editar</a>
            <form method="POST" action="/admin/horarios/<%= h.id %>/eliminar" style="display:inline" onsubmit="return confirm('¿Eliminar este horario?')">
              <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (horarios.length === 0) { %>
        <tr><td colspan="5" class="text-center text-muted py-4">No hay horarios</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
