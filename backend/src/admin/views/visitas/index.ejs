<%- include('../layouts/header') %>
<header class="flex justify-between items-center mb-3">
  <div><span class="text-muted"><%= total %> visitas</span></div>
  <a href="/admin/visitas/nuevo" role="button" class="primary">Nueva Visita</a>
</header>
<form method="GET" class="flex gap-2 mb-3 items-center">
  <select name="empleadoId" style="width:auto">
    <option value="">Todos los empleados</option>
    <% empleados.forEach(e => { %>
      <option value="<%= e.id %>" <%= filtroEmpleadoId === e.id ? 'selected' : '' %>><%= e.apellido %>, <%= e.nombre %></option>
    <% }) %>
  </select>
  <button type="submit" class="secondary outline">Filtrar</button>
</form>
<table>
  <thead>
    <tr><th>Fecha</th><th>Hora</th><th>Pedido</th><th>Empleado</th><th>Falta</th><th></th></tr>
  </thead>
  <tbody>
    <% visitas.forEach(v => { %>
      <tr>
        <td><%= v.fecha.toLocaleDateString() %></td>
        <td><%= v.hora.toLocaleTimeString() %></td>
        <td><%= v.pedido.numeroPedido %></td>
        <td><%= v.empleado.apellido %>, <%= v.empleado.nombre %></td>
        <td>
          <span class="badge-<%= v.falta ? 'danger' : 'success' %>"><%= v.falta ? 'Sí' : 'No' %></span>
        </td>
        <td class="action-cell">
          <a href="/admin/visitas/<%= v.id %>/editar" role="button" class="secondary outline small-btn">Editar</a>
          <form method="POST" action="/admin/visitas/<%= v.id %>/eliminar" onsubmit="return confirm('¿Eliminar esta visita?')">
            <button type="submit" class="secondary outline small-btn">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (visitas.length === 0) { %>
      <tr><td colspan="6" class="text-center text-muted" style="padding:1rem 0">No hay visitas</td></tr>
    <% } %>
  </tbody>
</table>
<% const totalPages = Math.ceil(total / pageSize); %>
<%- include('../layouts/pagination', { totalPages, currentPage: page, qs }) %>
<%- include('../layouts/footer') %>
