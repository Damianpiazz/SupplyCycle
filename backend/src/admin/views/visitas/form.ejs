<%- include('../layouts/header') %>
<a href="/admin/visitas" class="secondary outline small-btn mb-2">&larr; Volver</a>
<article>
  <header><strong><%= visita ? 'Editar' : 'Nueva' %> Visita</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>
  <form method="POST" action="/admin/visitas<%= visita ? '/' + visita.id : '' %>">
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="fecha">Fecha
        <input type="date" id="fecha" name="fecha" value="<%= visita ? new Date(visita.fecha.getTime() - visita.fecha.getTimezoneOffset() * 60000).toISOString().slice(0, 10) : '' %>" required>
      </label>
      <label for="hora">Hora
        <input type="datetime-local" id="hora" name="hora" value="<%= visita ? new Date(visita.hora.getTime() - visita.hora.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>" required>
      </label>
    </div>
    <label for="falta">
      <input type="checkbox" id="falta" name="falta" value="true" role="switch" <%= visita && visita.falta ? 'checked' : '' %>>
      Marcar como falta
    </label>
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label for="pedidoId">Pedido
        <select id="pedidoId" name="pedidoId" required>
          <option value="">Seleccionar pedido...</option>
          <% pedidos.forEach(p => { %>
            <option value="<%= p.id %>" <%= visita && visita.pedidoId === p.id ? 'selected' : '' %>><%= p.numeroPedido %> — <%= p.cliente.apellido %>, <%= p.cliente.nombre %></option>
          <% }) %>
        </select>
      </label>
      <label for="empleadoId">Empleado
        <select id="empleadoId" name="empleadoId" required>
          <option value="">Seleccionar empleado...</option>
          <% empleados.forEach(e => { %>
            <option value="<%= e.id %>" <%= visita && visita.empleadoId === e.id ? 'selected' : '' %>><%= e.apellido %>, <%= e.nombre %></option>
          <% }) %>
        </select>
      </label>
    </div>
    <footer class="flex gap-2">
      <button type="submit" class="primary"><%= visita ? 'Guardar Cambios' : 'Crear Visita' %></button>
      <a href="/admin/visitas" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>
<%- include('../layouts/footer') %>
