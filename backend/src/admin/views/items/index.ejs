<%- include('../layouts/header') %>

<header class="flex justify-between items-center mb-3">
  <div>
    <span class="text-muted"><%= items.length %> items</span>
  </div>
  <a href="/admin/items/nuevo" role="button" class="primary">Nuevo Item</a>
</header>

<form method="GET" class="flex gap-2 mb-3 items-center">
  <select name="activo" style="width:auto">
    <option value="">Todos</option>
    <option value="true" <%= filterActivo === 'true' ? 'selected' : '' %>>Activos</option>
    <option value="false" <%= filterActivo === 'false' ? 'selected' : '' %>>Inactivos</option>
  </select>
  <button type="submit" class="secondary outline">Filtrar</button>
</form>

<table>
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Descripción</th>
      <th>Unidad</th>
      <th>Precio</th>
      <th>Estado</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% items.forEach(i => { %>
      <tr>
        <td><%= i.nombre %></td>
        <td><%= i.descripcion || '-' %></td>
        <td><%= i.unidad %></td>
        <td><%= i.precio ? '$' + i.precio.toFixed(2) : '-' %></td>
        <td>
          <span class="badge-<%= i.activo ? 'activo' : 'inactivo' %>"><%= i.activo ? 'Activo' : 'Inactivo' %></span>
        </td>
        <td>
          <a href="/admin/items/<%= i.id %>/editar" role="button" class="secondary outline small-btn">Editar</a>
        </td>
      </tr>
    <% }) %>
    <% if (items.length === 0) { %>
      <tr><td colspan="6" class="text-center text-muted" style="padding:1rem 0">No hay items</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('../layouts/footer') %>
