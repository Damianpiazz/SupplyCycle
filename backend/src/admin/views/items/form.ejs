<%- include('../layouts/header') %>

<div class="mb-3">
  <a href="/admin/items" class="btn btn-outline-secondary btn-sm">&larr; Volver</a>
</div>

<div class="card">
  <div class="card-header"><strong><%= item ? 'Editar' : 'Nuevo' %> Item</strong></div>
  <div class="card-body">
    <% if (typeof errors.general !== 'undefined' && errors.general) { %>
      <div class="alert alert-danger"><%= errors.general %></div>
    <% } %>

    <form method="POST" action="/admin/items<%= item ? '/' + item.id : '' %>">
      <div class="mb-3">
        <label for="nombre" class="form-label">Nombre</label>
        <input type="text" class="form-control" id="nombre" name="nombre" value="<%= item ? item.nombre : '' %>" required>
      </div>

      <div class="mb-3">
        <label for="descripcion" class="form-label">Descripción</label>
        <textarea class="form-control" id="descripcion" name="descripcion" rows="2"><%= item ? (item.descripcion || '') : '' %></textarea>
      </div>

      <div class="row mb-3">
        <div class="col-md-4">
          <label for="unidad" class="form-label">Unidad</label>
          <input type="text" class="form-control" id="unidad" name="unidad" value="<%= item ? item.unidad : '' %>" required placeholder="ej: kg, un, litro">
        </div>
        <div class="col-md-4">
          <label for="precio" class="form-label">Precio</label>
          <input type="number" step="0.01" class="form-control" id="precio" name="precio" value="<%= item && item.precio ? item.precio : '' %>" placeholder="0.00">
        </div>
        <% if (item) { %>
          <div class="col-md-4">
            <label for="activo" class="form-label">Estado</label>
            <select class="form-select" id="activo" name="activo">
              <option value="true" <%= item.activo ? 'selected' : '' %>>Activo</option>
              <option value="false" <%= !item.activo ? 'selected' : '' %>>Inactivo</option>
            </select>
          </div>
        <% } %>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><%= item ? 'Guardar Cambios' : 'Crear Item' %></button>
        <a href="/admin/items" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../layouts/footer') %>
