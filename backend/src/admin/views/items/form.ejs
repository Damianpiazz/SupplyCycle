<%- include('../layouts/header') %>

<a href="/admin/items" class="secondary outline small-btn mb-2">&larr; Volver</a>

<article>
  <header><strong><%= item ? 'Editar' : 'Nuevo' %> Item</strong></header>
  <% if (typeof errors.general !== 'undefined' && errors.general) { %>
    <div class="alert alert-danger"><%= errors.general %></div>
  <% } %>

  <form method="POST" action="/admin/items<%= item ? '/' + item.id : '' %>">
    <label for="nombre">Nombre
      <input type="text" id="nombre" name="nombre" value="<%= item ? item.nombre : '' %>" required>
    </label>

    <label for="descripcion">Descripción
      <textarea id="descripcion" name="descripcion" rows="2"><%= item ? (item.descripcion || '') : '' %></textarea>
    </label>

    <div class="grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
      <label for="unidad">Unidad
        <input type="text" id="unidad" name="unidad" value="<%= item ? item.unidad : '' %>" required placeholder="ej: kg, un, litro">
      </label>
      <label for="precio">Precio
        <input type="number" step="0.01" id="precio" name="precio" value="<%= item && item.precio ? item.precio : '' %>" placeholder="0.00">
      </label>
      <% if (item) { %>
        <label for="activo">Estado
          <select id="activo" name="activo">
            <option value="true" <%= item.activo ? 'selected' : '' %>>Activo</option>
            <option value="false" <%= !item.activo ? 'selected' : '' %>>Inactivo</option>
          </select>
        </label>
      <% } %>
    </div>

    <footer class="flex gap-2">
      <button type="submit" class="primary"><%= item ? 'Guardar Cambios' : 'Crear Item' %></button>
      <a href="/admin/items" role="button" class="secondary outline">Cancelar</a>
    </footer>
  </form>
</article>

<%- include('../layouts/footer') %>
