<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>SupplyCycle Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
  <link href="/static/css/supplycycle-theme.css" rel="stylesheet">
</head>
<body>
  <nav class="sidebar">
    <div class="brand">SupplyCycle</div>
    <ul>
      <li><a href="/admin/pedidos" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/pedidos') ? 'active' : '' %>">Pedidos</a></li>
      <li><a href="/admin/clientes" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/clientes') ? 'active' : '' %>">Clientes</a></li>
      <li><a href="/admin/repartos" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/repartos') ? 'active' : '' %>">Repartos</a></li>
      <li><a href="/admin/items" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/items') ? 'active' : '' %>">Items</a></li>
      <li><a href="/admin/usuarios" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/usuarios') ? 'active' : '' %>">Usuarios</a></li>
      <li><a href="/admin/ciudades" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/ciudades') ? 'active' : '' %>">Ciudades</a></li>
      <li><a href="/admin/domicilios" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/domicilios') ? 'active' : '' %>">Domicilios</a></li>
      <li><a href="/admin/dias" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/dias') ? 'active' : '' %>">Días</a></li>
      <li><a href="/admin/horarios" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/horarios') ? 'active' : '' %>">Horarios</a></li>
      <li><a href="/admin/empleados" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/empleados') ? 'active' : '' %>">Empleados</a></li>
      <li><a href="/admin/visitas" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/visitas') ? 'active' : '' %>">Visitas</a></li>
      <li><a href="/admin/retenidos" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/retenidos') && !currentPath?.startsWith('/admin/retenidos/demorados') ? 'active' : '' %>">Retenidos</a></li>
      <li><a href="/admin/retenidos/demorados" class="<%= typeof currentPath !== 'undefined' && currentPath === '/admin/retenidos/demorados' ? 'active' : '' %>">Envases Demorados</a></li>
      <li><a href="/admin/reclamos" class="<%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/reclamos') ? 'active' : '' %>">Reclamos</a></li>
    </ul>
    <div class="user-section">
      <div class="user-name"><%= typeof userNombre !== 'undefined' ? userNombre : 'Admin' %></div>
      <form method="POST" action="/admin/logout">
        <button type="submit" class="logout-link" style="background:none;border:none;cursor:pointer;display:block;padding:0.25rem 0.75rem;width:100%;text-align:left;"><%= typeof userNombre !== 'undefined' ? 'Cerrar sesión' : 'Iniciar sesión' %></button>
      </form>
    </div>
  </nav>
  <main class="main-content">
    <div style="border-bottom:1px solid var(--pico-border-color);padding:0.75rem 0;margin-bottom:1rem;">
      <h5 style="margin:0;"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h5>
    </div>
    <div>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success" role="alert"><%= success %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger" role="alert"><%= error %></div>
      <% } %>
