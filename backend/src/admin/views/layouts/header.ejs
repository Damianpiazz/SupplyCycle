<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>SupplyCycle Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/static/css/admin.css" rel="stylesheet">
</head>
<body>
<div class="d-flex">
  <nav class="sidebar d-flex flex-column flex-shrink-0 p-3 text-white">
    <a href="/admin" class="d-flex align-items-center mb-3 text-white text-decoration-none">
      <span class="fs-5 fw-semibold">SupplyCycle</span>
    </a>
    <hr>
    <ul class="nav nav-pills flex-column mb-auto">
      <li class="nav-item">
        <a href="/admin/pedidos" class="nav-link text-white <%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/pedidos') ? 'active' : '' %>">Pedidos</a>
      </li>
      <li class="nav-item">
        <a href="/admin/clientes" class="nav-link text-white <%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/clientes') ? 'active' : '' %>">Clientes</a>
      </li>
      <li class="nav-item">
        <a href="/admin/repartos" class="nav-link text-white <%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/repartos') ? 'active' : '' %>">Repartos</a>
      </li>
      <li class="nav-item">
        <a href="/admin/items" class="nav-link text-white <%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/items') ? 'active' : '' %>">Items</a>
      </li>
      <li class="nav-item">
        <a href="/admin/usuarios" class="nav-link text-white <%= typeof currentPath !== 'undefined' && currentPath?.startsWith('/admin/usuarios') ? 'active' : '' %>">Usuarios</a>
      </li>
    </ul>
    <hr>
    <div class="dropdown">
      <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
        <strong><%= typeof userNombre !== 'undefined' ? userNombre : 'Admin' %></strong>
      </a>
      <ul class="dropdown-menu dropdown-menu-dark">
        <li>
          <form method="POST" action="/admin/logout">
            <button type="submit" class="dropdown-item">Cerrar sesión</button>
          </form>
        </li>
      </ul>
    </div>
  </nav>
  <main class="flex-grow-1 min-vh-100 bg-light">
    <div class="bg-white border-bottom px-4 py-3">
      <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h5>
    </div>
    <div class="container-fluid p-4">
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
      <% } %>
