# =========================================
# ENVIRONMENT
# =========================================
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_APP_NAME=SupplyCycle
EXPO_PUBLIC_APP_VERSION=1.0.0

# =========================================
# API CONFIGURATION
# =========================================
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_API_TIMEOUT=15000
EXPO_PUBLIC_API_RETRY_COUNT=3
EXPO_PUBLIC_API_VERSION=1

# =========================================
# AUTH (NO secrets)
# =========================================
EXPO_PUBLIC_AUTH_ENABLED=true
EXPO_PUBLIC_AUTH_TOKEN_KEY=auth_token
EXPO_PUBLIC_REFRESH_TOKEN_KEY=refresh_token

# =========================================
# NETWORK / DEBUG
# =========================================
EXPO_PUBLIC_ENABLE_LOGS=true
EXPO_PUBLIC_ENABLE_NETWORK_LOGS=false
EXPO_PUBLIC_ENABLE_DEVTOOLS=false

# =========================================
# FEATURE FLAGS
# =========================================
EXPO_PUBLIC_FEATURE_CHAT=false
EXPO_PUBLIC_FEATURE_NOTIFICATIONS=false
EXPO_PUBLIC_FEATURE_ANALYTICS=false
EXPO_PUBLIC_FEATURE_DARK_MODE=true

# =========================================
# MISC
# =========================================
EXPO_PUBLIC_DEFAULT_LANGUAGE=es
EXPO_PUBLIC_SUPPORTED_LANGUAGES=es
